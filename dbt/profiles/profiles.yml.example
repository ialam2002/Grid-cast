gridcast_dbt:
  # Active target is driven by the DBT_TARGET env var at render time; default = dev.
  target: "{{ env_var('DBT_TARGET', 'dev') }}"
  outputs:
    dev:
      type: athena
      # Example: s3://gridcast-dev-dbt-staging/query-results/
      s3_staging_dir: "{{ env_var('DBT_ATHENA_S3_STAGING_DIR') }}"
      region_name: "{{ env_var('AWS_REGION', 'us-west-2') }}"
      schema: gridcast_dev_gold
      database: "{{ env_var('DBT_ATHENA_DATABASE', 'AwsDataCatalog') }}"
      work_group: "{{ env_var('DBT_ATHENA_WORKGROUP', 'gridcast-dev') }}"
      threads: 4
      aws_profile_name: "{{ env_var('AWS_PROFILE', '') }}"
      role_arn: "{{ env_var('DBT_ATHENA_ROLE_ARN_DEV', '') }}"
      num_retries: 3
      poll_interval: 5
      retry_all: true
    stage:
      type: athena
      # Example: s3://gridcast-stage-dbt-staging/query-results/
      s3_staging_dir: "{{ env_var('DBT_ATHENA_S3_STAGING_DIR') }}"
      region_name: "{{ env_var('AWS_REGION', 'us-west-2') }}"
      schema: gridcast_stage_gold
      database: "{{ env_var('DBT_ATHENA_DATABASE', 'AwsDataCatalog') }}"
      work_group: "{{ env_var('DBT_ATHENA_WORKGROUP', 'gridcast-stage') }}"
      threads: 4
      aws_profile_name: "{{ env_var('AWS_PROFILE', '') }}"
      role_arn: "{{ env_var('DBT_ATHENA_ROLE_ARN_STAGE', '') }}"
      num_retries: 3
      poll_interval: 5
      retry_all: true
    prod:
      type: athena
      # Example: s3://gridcast-prod-dbt-staging/query-results/
      s3_staging_dir: "{{ env_var('DBT_ATHENA_S3_STAGING_DIR') }}"
      region_name: "{{ env_var('AWS_REGION', 'us-west-2') }}"
      schema: gridcast_prod_gold
      database: "{{ env_var('DBT_ATHENA_DATABASE', 'AwsDataCatalog') }}"
      work_group: "{{ env_var('DBT_ATHENA_WORKGROUP', 'gridcast-prod') }}"
      threads: 4
      aws_profile_name: "{{ env_var('AWS_PROFILE', '') }}"
      role_arn: "{{ env_var('DBT_ATHENA_ROLE_ARN_PROD', '') }}"
      num_retries: 5
      poll_interval: 5
      retry_all: true

