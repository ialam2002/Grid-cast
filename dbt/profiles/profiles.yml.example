gridcast_dbt:
  target: dev
  outputs:
    dev:
      type: athena
      s3_staging_dir: "{{ env_var('DBT_ATHENA_S3_STAGING_DIR') }}"
      region_name: "{{ env_var('AWS_REGION', 'us-west-2') }}"
      schema: "{{ env_var('DBT_ATHENA_SCHEMA', 'gold') }}"
      database: "{{ env_var('DBT_ATHENA_DATABASE', 'AwsDataCatalog') }}"
      work_group: "{{ env_var('DBT_ATHENA_WORKGROUP', 'primary') }}"
      threads: 4
      aws_profile_name: "{{ env_var('AWS_PROFILE', '') }}"
      num_retries: 3
      poll_interval: 5
      retry_all: true
    stage:
      type: athena
      s3_staging_dir: "{{ env_var('DBT_ATHENA_S3_STAGING_DIR_STAGE') }}"
      region_name: "{{ env_var('AWS_REGION', 'us-west-2') }}"
      schema: "{{ env_var('DBT_ATHENA_SCHEMA_STAGE', 'gold') }}"
      database: "{{ env_var('DBT_ATHENA_DATABASE', 'AwsDataCatalog') }}"
      work_group: "{{ env_var('DBT_ATHENA_WORKGROUP', 'primary') }}"
      threads: 4
      aws_profile_name: "{{ env_var('AWS_PROFILE', '') }}"
      num_retries: 3
      poll_interval: 5
      retry_all: true

